# Application display name shown in the UI.
APP_NAME="Local AI Task Hub"

# Prisma database connection string. Default uses a local SQLite file.
DATABASE_URL="file:./dev.db"

# Agent runtime provider. Keep `openclaw` for the built-in OpenClaw workflow.
AGENT_RUNTIME_KIND="openclaw"

# Reserved runtime base URL. Keep the default unless you add an external bridge service.
AGENT_RUNTIME_BASE_URL="http://127.0.0.1:4100"

# Poller interval in milliseconds. Controls how often TODO tasks are scanned.
TASK_POLLER_INTERVAL_MS="30000"

# Number of tasks processed per poller cycle.
TASK_POLLER_BATCH_SIZE="1"

# Optional project slug allowlist. Leave empty to process all projects.
TASK_POLLER_PROJECT_SLUGS=""

# Optional token for protecting the poller API endpoint.
TASK_POLLER_TOKEN=""
